{
  "expo": {
    "name": "SEQ Transit",
    "slug": "seq-transit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brisbanebus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ef60a3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.wycs.seqtransit",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDJTr3x-CA2UqSq5mXzTqS9MLSkDTlmKCw"
        }
      }
    },
    "platforms": ["android"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ef60a3",
          "dark": {
            "backgroundColor": "#ef60a3"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b4a62e8-c8b8-47d2-a997-1b9f15acddf8"
      }
    }
  }
}
